# AgentCore Auto-Registration CLI Configuration
# Copy this file to .env and update with your values
#
# Usage: python -m cli.agentcore sync
# Docs:  docs/agentcore-auto-registration-prerequisites.md

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# Region to scan for AgentCore resources
AWS_REGION=us-east-1

# AWS credentials (uses standard boto3 credential chain)
# Uncomment if not using IAM role, AWS CLI profile, or other credential source
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# =============================================================================
# REGISTRY CONFIGURATION
# =============================================================================
# MCP Gateway Registry URL
REGISTRY_URL=http://localhost

# Path to registry authentication token (for API calls)
REGISTRY_TOKEN_FILE=.oauth-tokens/ingress.json

# =============================================================================
# OAUTH2 DOMAIN CONFIGURATION
# =============================================================================
# OAuth2 provider domain URL (required for CUSTOM_JWT gateways)
# Used for credential validation and token generation
#
# Cognito:  https://your-domain.auth.us-east-1.amazoncognito.com
# Auth0:    https://your-tenant.auth0.com
# Okta:     https://your-org.okta.com
# Custom:   https://auth.yourcompany.com

OAUTH_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# Optional: Cognito User Pool ID (for Cognito-specific features)
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# =============================================================================
# GATEWAY 1: CUSTOM_JWT (OAuth2) EXAMPLE
# =============================================================================
# For gateways using OAuth2 authentication (Cognito, Auth0, Okta, etc.)
# Requires: Client ID, Client Secret, Gateway ARN, Server Name

AGENTCORE_CLIENT_ID_1=your-oauth-client-id
AGENTCORE_CLIENT_SECRET_1=your-oauth-client-secret
AGENTCORE_GATEWAY_ARN_1=arn:aws:bedrock:us-east-1:123456789012:gateway/gw-oauth-example
AGENTCORE_SERVER_NAME_1=my-oauth-gateway
AGENTCORE_AUTHORIZER_TYPE_1=CUSTOM_JWT

# =============================================================================
# GATEWAY 2: AWS_IAM EXAMPLE
# =============================================================================
# For gateways using AWS IAM (SigV4) authentication
# No OAuth2 credentials needed - uses AWS credential chain

# AGENTCORE_GATEWAY_ARN_2=arn:aws:bedrock:us-east-1:123456789012:gateway/gw-iam-example
# AGENTCORE_SERVER_NAME_2=my-iam-gateway
# AGENTCORE_AUTHORIZER_TYPE_2=AWS_IAM

# =============================================================================
# GATEWAY 3: NONE (No Auth) EXAMPLE
# =============================================================================
# For public gateways with no authentication
# No credentials needed

# AGENTCORE_GATEWAY_ARN_3=arn:aws:bedrock:us-east-1:123456789012:gateway/gw-public-example
# AGENTCORE_SERVER_NAME_3=my-public-gateway
# AGENTCORE_AUTHORIZER_TYPE_3=NONE

# =============================================================================
# ADDITIONAL GATEWAYS
# =============================================================================
# Add more gateways using incrementing indices: _4, _5, _6, ... up to _100
#
# AGENTCORE_CLIENT_ID_4=...
# AGENTCORE_CLIENT_SECRET_4=...
# AGENTCORE_GATEWAY_ARN_4=...
# AGENTCORE_SERVER_NAME_4=...
# AGENTCORE_AUTHORIZER_TYPE_4=CUSTOM_JWT

# =============================================================================
# CROSS-ACCOUNT SCANNING
# =============================================================================
# Comma-separated AWS account IDs to scan (leave empty for current account only)
# The CLI will assume a role in each account to discover resources.
# AGENTCORE_ACCOUNTS=111111111111,222222222222,333333333333

# IAM role name to assume in each target account (default: AgentCoreSyncRole)
# The role must exist in each target account and trust the caller's account.
# AGENTCORE_ASSUME_ROLE_NAME=AgentCoreSyncRole

# =============================================================================
# TOKEN GENERATION SETTINGS
# =============================================================================
# Timeout for token generation requests (seconds)
TOKEN_GENERATION_TIMEOUT=30
